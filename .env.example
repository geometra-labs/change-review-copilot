# API
API_HOST=0.0.0.0
API_PORT=8000
APP_ENV=development
SECRET_KEY=replace_me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/crc

# Storage
STORAGE_BUCKET=crc-dev
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=miniosecret
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false

# Upload limits
MAX_UPLOAD_MB=100
ALLOWED_EXTENSIONS=.step,.stp,.stl,.obj,.glb,.json

# Jobs
JOB_POLL_INTERVAL_SECONDS=2
JOB_MAX_RUNTIME_SECONDS=300

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
LLM_MODEL=gpt-5.4-mini
LLM_TIMEOUT_SECONDS=20

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
